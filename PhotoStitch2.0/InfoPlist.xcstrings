    "NSPhotoLibraryUsageDescription": {
      "comment": "Privacy - Photo Library Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Please allow this app to import from your selected photos for editing. "
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택한 사진을 가져와 편집할 수 있도록 사진 접근을 허용해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请允许此 App 导入你所选的照片以进行编辑。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請允許此 App 匯入你所選的照片以進行編輯。"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يُرجى السماح لهذا التطبيق باستيراد الصور التي تحددها لتحريرها."
          }
        }
      }
