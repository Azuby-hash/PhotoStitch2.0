    "Record a slow scroll on your screen and import the video — Photo Stitch converts it into one seamless long screenshot." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سجّل تمريرًا بطيئًا على شاشتك ثم استورد الفيديو — يحوّله Photo Stitch إلى لقطة شاشة طويلة ومتّصلة."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "화면을 천천히 스크롤하며 녹화한 뒤 동영상을 불러오세요. Photo Stitch가 매끄러운 하나의 긴 스크린샷으로 만들어 드립니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "缓慢滚动屏幕进行录制，然后导入视频 —— Photo Stitch 会将其转换为一张无缝的长截图。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "緩慢捲動畫面進行錄製，然後匯入影片 —— Photo Stitch 會將其轉換為一張無縫的長截圖。"
          }
        }
      }
    },
