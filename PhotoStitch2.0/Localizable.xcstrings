    "Combine multiple screenshots into one clean, seamless image in seconds." : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ادمج عدة لقطات شاشة في صورة واحدة نظيفة ومتّصلة خلال ثوانٍ."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여러 스크린샷을 단 몇 초 만에 깔끔하고 매끄러운 하나의 이미지로 합쳐보세요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "几秒钟即可将多张截图合成一张干净、无缝的长图。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "幾秒鐘即可將多張截圖合成一張乾淨、無縫的長圖。"
          }
        }
      }
    },
    "Convert recording into long image." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "حوّل التسجيل إلى صورة طويلة."
